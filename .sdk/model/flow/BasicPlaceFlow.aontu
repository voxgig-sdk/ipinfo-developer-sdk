# BasicPlaceFlow

main: kit: flow: BasicPlaceFlow:
{
  entity: "place",
  kind: "basic",
  name: "BasicPlaceFlow",
  step: [
    {
      input: {
        ref: "place_ref01",
        srcdatavar: "place_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "place01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-place_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicPlaceFlow"
}