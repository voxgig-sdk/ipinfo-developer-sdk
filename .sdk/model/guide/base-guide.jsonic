    path: "/whois/net/AS{asn}": {
      op: list: method: *GET
    }
  }

  entity: whois_domain: {
    path: "/whois/net/{domain}": {
      op: load: method: *GET
    }
  }

  entity: whois_ip: {
    path: "/whois/net/{whoisip}": {
      op: load: method: *GET
    }
  }

  entity: whois_net_id: {
